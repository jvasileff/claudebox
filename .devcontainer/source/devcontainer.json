{
    "name": "Claude Code Sandbox (source)",
    "remoteUser": "coder",
    "mounts": [
        "source=claude-code-${devcontainerId},target=/home/coder/.claude,type=volume"
    ],
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/project,type=bind,consistency=cached",
    "workspaceFolder": "/workspaces/project",
    "remoteEnv": {
        "DEVCONTAINER": "1"
    },
    "postStartCommand": "/usr/local/libexec/container-init.sh",
    "waitFor": "postStartCommand",
    "build": {
        "dockerfile": "../../Dockerfile",
        "context": "../../context"
    }
}
