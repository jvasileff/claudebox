{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "switchModelsOnFlag": false,
  "autoUpdatesChannel": "stable",
  "theme": "auto",
  "worktree": {
    "bgIsolation": "none"
  },
  "env": {
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  }
}
