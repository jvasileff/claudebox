{
    "name": "Claude Code Sandbox (prebuilt)",
    "image": "ghcr.io/jvasileff/claudebox:latest",
    "remoteUser": "coder",
    "workspaceFolder": "/workspaces/project",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/project,type=bind",
    "mounts": [
        "source=claude-code-${devcontainerId},target=/home/coder/.claude,type=volume"
    ],
    "remoteEnv": {
        "DEVCONTAINER": "1"
    },
    "postStartCommand": "/usr/local/libexec/container-init.sh",
    "waitFor": "postStartCommand"
}
